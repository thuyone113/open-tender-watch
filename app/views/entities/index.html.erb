<div class="animate-fade-up">
  <%# Header %>
  <header class="py-8 border-b border-white/10">
    <div class="mb-1">
      <%= link_to root_path, class: "font-mono text-[11px] tracking-[2px] text-white/30 hover:text-white/60 transition-colors" do %>
        ← <%= t("nav.dashboard") %>
      <% end %>
    </div>
    <h1 class="font-['Space_Grotesk'] text-3xl font-bold tracking-tight bg-gradient-to-r from-[#e8e0d4] to-[#c8a84e] bg-clip-text text-transparent mb-1 mt-2">
      <%= t("entities.index.title") %>
    </h1>
    <p class="text-white/35 text-sm">
      <%= t("entities.index.subtitle", total: number_with_delimiter(@total)) %>
    </p>
  </header>

  <%# Filters %>
  <turbo-frame id="entities-table">
    <%= form_with url: entities_path, method: :get, class: "flex flex-wrap gap-2 my-6" do |f| %>
      <div class="flex-1 min-w-[180px]">
        <%= f.text_field :q, value: params[:q],
            placeholder: t("entities.index.search_placeholder"),
            class: "w-full bg-white/[0.04] border border-white/[0.1] rounded px-3 py-2 font-mono text-xs text-[#e8e0d4] placeholder-white/20 focus:outline-none focus:border-[#c8a84e55] transition-all" %>
      </div>
      <div>
        <%= f.select :type,
          [
            [t("entities.index.all_types"), ""],
            [t("entities.index.public_only"), "public"],
            [t("entities.index.private_only"), "private"]
          ],
          { selected: params[:type] },
          class: "bg-white/[0.04] border border-white/[0.1] rounded px-3 py-2 font-mono text-xs text-[#e8e0d4] focus:outline-none focus:border-[#c8a84e55] transition-all" %>
      </div>
      <%= f.submit t("entities.index.filter"),
          class: "bg-[#c8a84e1a] border border-[#c8a84e44] text-[#c8a84e] font-mono text-xs tracking-widest px-4 py-2 rounded hover:bg-[#c8a84e33] transition-all cursor-pointer" %>
      <% if params[:q].present? || params[:type].present? %>
        <%= link_to t("entities.index.clear"), entities_path,
            class: "border border-white/10 text-white/30 font-mono text-xs tracking-widest px-4 py-2 rounded hover:text-white/50 transition-all" %>
      <% end %>
    <% end %>

    <%# Table %>
    <div class="border border-white/[0.08] rounded-lg overflow-hidden">
      <div class="grid grid-cols-[1fr_100px_90px_80px] sm:grid-cols-[1fr_140px_100px_90px] bg-white/[0.03] px-4 sm:px-5 py-3 border-b border-white/[0.08] font-mono text-[10px] tracking-[2px] text-white/35 uppercase">
        <span><%= t("entities.index.col_entity") %></span>
        <span class="hidden sm:block"><%= t("entities.index.col_country") %></span>
        <span class="text-center"><%= t("entities.index.col_type") %></span>
        <span class="text-right"><%= t("entities.index.col_contracts") %></span>
      </div>

      <% if @entities.empty? %>
        <div class="px-5 py-12 text-center font-mono text-sm text-white/25">
          <%= t("entities.index.empty") %>
        </div>
      <% else %>
        <% @entities.each do |entity| %>
          <%= link_to entity_path(entity), class: "grid grid-cols-[1fr_100px_90px_80px] sm:grid-cols-[1fr_140px_100px_90px] px-4 sm:px-5 py-3.5 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.03] transition-colors group items-center" do %>
            <div class="pr-3">
              <div class="text-sm text-[#e8e0d4] group-hover:text-white transition-colors leading-snug line-clamp-2">
                <%= entity.name %>
              </div>
              <div class="font-mono text-[10px] text-white/25 mt-0.5">NIF <%= entity.tax_identifier %></div>
            </div>
            <div class="hidden sm:block font-mono text-xs text-white/40"><%= entity.country_code %></div>
            <div class="text-center">
              <% if entity.is_public_body? %>
                <span class="font-mono text-[9px] tracking-wide text-[#c8a84e] bg-[#c8a84e12] border border-[#c8a84e33] px-1.5 py-0.5 rounded">
                  <%= t("entities.index.public") %>
                </span>
              <% else %>
                <span class="font-mono text-[9px] tracking-wide text-white/40 bg-white/[0.04] border border-white/[0.08] px-1.5 py-0.5 rounded">
                  <%= t("entities.index.private") %>
                </span>
              <% end %>
            </div>
            <div class="text-right font-mono text-xs text-[#c8a84e] font-medium">
              <%= number_with_delimiter(entity.contract_count.to_i) %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# Pagination %>
    <% if @total_pages > 1 %>
      <div class="flex items-center justify-between mt-6 font-mono text-xs text-white/35">
        <span>
          <%= t("entities.index.pagination.info", page: @page, total_pages: @total_pages, total: number_with_delimiter(@total)) %>
        </span>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to t("entities.index.pagination.prev"),
                entities_path(request.query_parameters.merge(page: @page - 1)),
                class: "border border-white/10 px-3 py-1.5 rounded hover:border-[#c8a84e44] hover:text-[#c8a84e] transition-all" %>
          <% end %>
          <% if @page < @total_pages %>
            <%= link_to t("entities.index.pagination.next"),
                entities_path(request.query_parameters.merge(page: @page + 1)),
                class: "border border-white/10 px-3 py-1.5 rounded hover:border-[#c8a84e44] hover:text-[#c8a84e] transition-all" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </turbo-frame>
</div>
