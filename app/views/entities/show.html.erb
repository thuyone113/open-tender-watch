<div class="animate-fade-up">
  <%# Header %>
  <header class="py-8 border-b border-white/10">
    <div class="flex items-center gap-4 mb-3">
      <%= link_to entities_path, class: "font-mono text-[11px] tracking-[2px] text-white/30 hover:text-white/60 transition-colors" do %>
        ← <%= t("entities.index.title") %>
      <% end %>
      <% if @entity.is_public_body? %>
        <span class="font-mono text-[10px] text-[#c8a84e] bg-[#c8a84e12] px-2 py-0.5 rounded border border-[#c8a84e33]">
          <%= t("entities.show.public_body") %>
        </span>
      <% else %>
        <span class="font-mono text-[10px] text-white/40 bg-white/[0.04] px-2 py-0.5 rounded border border-white/[0.08]">
          <%= t("entities.show.company") %>
        </span>
      <% end %>
    </div>
    <h1 class="font-['Space_Grotesk'] text-2xl font-bold text-[#e8e0d4] leading-snug mb-2">
      <%= @entity.name %>
    </h1>
    <div class="font-mono text-[11px] text-white/25">
      NIF <%= @entity.tax_identifier %>
      · <%= @entity.country_code %>
    </div>
  </header>

  <div class="flex flex-col-reverse lg:grid lg:grid-cols-[1fr_280px] gap-6 mt-6">

    <%# Contract list %>
    <div>
      <%= turbo_frame_tag "entity-contracts",
            data: {
              controller: "entity-contracts",
              action: "turbo:before-fetch-request->entity-contracts#start turbo:frame-load->entity-contracts#finish"
            } do %>
        <%# Flag filter chips %>
        <% if @flag_types.any? %>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="font-mono text-[10px] tracking-[2px] text-white/35 uppercase shrink-0"><%= t("entities.show.filter_by_flag") %>:</span>
            <%= link_to entity_path(@entity, sort: @sort_col, dir: @sort_dir, page: 1),
                  class: "font-mono text-[10px] px-2.5 py-1 rounded border transition-all #{@flag_filter.nil? ? 'border-white/30 text-white/60 bg-white/[0.06]' : 'border-white/10 text-white/30 hover:text-white/60 hover:border-white/20'}" do %>
              <%= t("entities.show.filter_all_flags") %>
            <% end %>
            <% @flag_types.each do |ft| %>
              <% active_ft = @flag_filter == ft %>
              <% chip_color = active_ft ? "border-[#c8a84e66] text-[#c8a84e] bg-[#c8a84e0d]" : "border-white/10 text-white/30 hover:text-white/60 hover:border-white/20" %>
              <%= link_to entity_path(@entity, sort: @sort_col, dir: @sort_dir, flag_type: ft, page: 1),
                    class: "font-mono text-[10px] px-2.5 py-1 rounded border transition-all #{chip_color}" do %>
                <%= flag_type_label(ft) %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <%# Sort controls %>
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[10px] tracking-[2px] text-white/35 uppercase"><%= t("entities.show.sort_by") %>:</span>
          <% [["celebration_date", t("entities.show.sort_date")], ["base_price", t("entities.show.sort_price")], ["object", t("entities.show.sort_object")]].each do |col, label| %>
            <% active = @sort_col == col %>
            <% next_dir = (active && @sort_dir == "desc") ? "asc" : "desc" %>
            <%= link_to entity_path(@entity, sort: col, dir: next_dir, flag_type: @flag_filter, page: 1),
                  class: "font-mono text-[10px] tracking-[1px] px-2.5 py-1 rounded border transition-all #{active ? 'border-[#c8a84e66] text-[#c8a84e] bg-[#c8a84e0d]' : 'border-white/10 text-white/35 hover:text-white/60 hover:border-white/20'}" do %>
              <%= label %>
              <% if active %>
                <%= @sort_dir == "asc" ? " ↑" : " ↓" %>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <%# Pagination info%>
        <% if @total_pages > 1 || @total > 0 %>
          <p class="font-mono text-[11px] text-white/30 mb-3">
            <%= t("contracts.index.pagination.info", page: @page, total_pages: [@total_pages, 1].max, total: number_with_delimiter(@total)) %>
          </p>
        <% end %>

        <%# Table %>
        <div class="border border-white/[0.08] rounded-lg overflow-hidden">
          <%# Header row %>
          <div class="hidden sm:grid grid-cols-[1fr_140px_100px_90px] bg-white/[0.03] px-4 py-3 border-b border-white/[0.08] font-mono text-[10px] tracking-[2px] text-white/35 uppercase">
            <span><%= t("contracts.index.col_contract") %></span>
            <span><%= t("contracts.index.col_procedure") %></span>
            <span class="text-right"><%= t("contracts.index.col_price") %></span>
            <span class="text-right"><%= t("contracts.index.col_date") %></span>
          </div>

          <% if @contracts.empty? %>
            <div class="px-5 py-12 text-center font-mono text-sm text-white/25">
              <%= t("contracts.index.empty") %>
            </div>
          <% else %>
            <% @contracts.each do |contract| %>
              <%= link_to contract_path(contract), class: "flex flex-col sm:grid sm:grid-cols-[1fr_140px_100px_90px] px-4 py-3 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.03] transition-colors group sm:items-start gap-1 sm:gap-0", data: { turbo_frame: "_top" } do %>
                <div class="pr-0 sm:pr-4">
                  <div class="text-sm text-[#e8e0d4] group-hover:text-white transition-colors line-clamp-2 leading-snug">
                    <%= contract.object %>
                  </div>
                  <div class="font-mono text-[10px] text-white/25 mt-1">
                    <%= contract.country_code %> · <%= contract.external_id %>
                  </div>
                  <% if contract.flags.any? %>
                    <div class="mt-1.5 flex flex-wrap gap-1">
                      <% contract.flags.first(2).each do |flag| %>
                        <span class="font-mono text-[9px] tracking-wide text-[#ff6666] bg-[#ff444412] border border-[#ff444433] px-1.5 py-0.5 rounded">
                          <%= flag_type_label(flag.flag_type) %>
                        </span>
                      <% end %>
                      <% if contract.flags.size > 2 %>
                        <span class="font-mono text-[9px] text-white/35">+<%= contract.flags.size - 2 %></span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
                <div class="flex items-center gap-2 sm:block">
                  <% if contract.procedure_type.present? %>
                    <span class="font-mono text-[10px] text-white/40 bg-white/[0.04] px-2 py-0.5 rounded border border-white/[0.06] leading-tight inline-block sm:mt-0.5">
                      <%= contract.procedure_type.truncate(20) %>
                    </span>
                  <% end %>
                  <% if contract.base_price.present? %>
                    <span class="font-mono text-xs text-[#c8a84e] font-medium sm:hidden">
                      €<%= number_with_delimiter(contract.base_price.to_i) %>
                    </span>
                  <% end %>
                  <span class="font-mono text-[10px] text-white/30 sm:hidden">
                    <%= contract.celebration_date&.strftime("%Y-%m-%d") %>
                  </span>
                </div>
                <div class="hidden sm:block text-right font-mono text-xs text-[#c8a84e] font-medium pt-0.5">
                  <% if contract.base_price.present? %>
                    €<%= number_with_delimiter(contract.base_price.to_i) %>
                  <% else %>
                    <span class="text-white/20">—</span>
                  <% end %>
                </div>
                <div class="hidden sm:block text-right font-mono text-[11px] text-white/35 pt-0.5">
                  <%= contract.celebration_date&.strftime("%Y-%m-%d") || "—" %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <%# Pagination %>
        <% if @total_pages > 1 %>
          <div class="flex items-center justify-end mt-4 font-mono text-xs text-white/35 gap-2">
            <% if @page > 1 %>
              <%= link_to t("contracts.index.pagination.prev"),
                    entity_path(@entity, sort: @sort_col, dir: @sort_dir, flag_type: @flag_filter, page: @page - 1),
                    class: "border border-white/10 px-3 py-1.5 rounded hover:border-[#c8a84e44] hover:text-[#c8a84e] transition-all" %>
            <% end %>
            <% if @page < @total_pages %>
              <%= link_to t("contracts.index.pagination.next"),
                    entity_path(@entity, sort: @sort_col, dir: @sort_dir, flag_type: @flag_filter, page: @page + 1),
                    class: "border border-white/10 px-3 py-1.5 rounded hover:border-[#c8a84e44] hover:text-[#c8a84e] transition-all" %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Sidebar %>
    <div class="space-y-4">

      <%# Summary stats %>
      <div class="bg-white/[0.02] border border-white/[0.06] rounded-lg p-5">
        <div class="font-mono text-[10px] tracking-[2px] text-white/35 mb-4 uppercase"><%= t("entities.show.overview") %></div>
        <div class="space-y-3">
          <div>
            <div class="font-mono text-[10px] text-white/30 mb-0.5"><%= t("entities.show.total_contracts") %></div>
            <div class="font-['Space_Grotesk'] text-2xl font-bold text-[#c8a84e]">
              <%= number_with_delimiter(@entity_contract_total) %>
            </div>
          </div>
        </div>
      </div>

      <%# Flag stats %>
      <% if @flag_stats.any? %>
        <div class="bg-white/[0.02] border border-white/[0.06] rounded-lg p-5">
          <div class="font-mono text-[10px] tracking-[2px] text-white/35 mb-4 uppercase"><%= t("entities.show.risk_flags") %></div>
          <div class="space-y-3">
            <% @flag_stats.each do |stat| %>
              <% color = stat.severity == "high" ? "text-[#ff4444]" : stat.severity == "medium" ? "text-[#ff8844]" : "text-[#c8a84e]" %>
              <div class="border-b border-white/5 pb-3 last:border-0 last:pb-0">
                <div class="font-mono text-[10px] <%= color %> mb-1">
                  <%= flag_type_label(stat.flag_type) %>
                </div>
                <div class="flex items-baseline justify-between">
                  <span class="font-['Space_Grotesk'] text-sm font-bold text-[#e8e0d4]">
                    <%= number_to_currency(stat.total_exposure.to_f, unit: "€", delimiter: ",", separator: ".", format: "%u%n", precision: 0) %>
                  </span>
                  <span class="font-mono text-[10px] text-white/35">
                    <%= number_with_delimiter(stat.contract_count.to_i) %> contratos
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>
